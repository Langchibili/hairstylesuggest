# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_CLIENT=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=hairstylesuggest
DATABASE_USERNAME=hairstylesuggest_user
DATABASE_PASSWORD=hairstylesuggest_pass

# ── Strapi secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
APP_KEYS=changeme1,changeme2,changeme3,changeme4
API_TOKEN_SALT=changeme_salt_32chars_minimum___
ADMIN_JWT_SECRET=changeme_admin_jwt_32chars____
TRANSFER_TOKEN_SALT=changeme_transfer_salt________
JWT_SECRET=changeme_jwt_secret_64chars_____________________________________________

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=hairstylesuggest-assets
R2_PUBLIC_URL=https://pub-your-id.r2.dev
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
INTERNAL_SERVICE_KEY=changeme_internal_service_key_64chars_______________________________

# ── App ───────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337
NODE_ENV=development
