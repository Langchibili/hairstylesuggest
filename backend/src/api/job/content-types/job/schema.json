{
  "kind": "collectionType",
  "collectionName": "jobs",
  "info": {
    "singularName": "job",
    "pluralName": "jobs",
    "displayName": "Job",
    "description": "AI generation job queue"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "session": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::style-gen-session.style-gen-session",
      "inversedBy": "jobs"
    },
    "generation_result_id": {
      "type": "string",
      "maxLength": 36
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "preview_batch",
        "focus_render",
        "style_extraction"
      ],
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "queued",
        "running",
        "complete",
        "failed",
        "retrying"
      ],
      "default": "queued",
      "required": true
    },
    "payload": {
      "type": "json"
    },
    "runpod_job_id": {
      "type": "string",
      "maxLength": 100
    },
    "attempt_count": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "error_message": {
      "type": "text"
    },
    "queued_at": {
      "type": "datetime"
    },
    "started_at": {
      "type": "datetime"
    },
    "completed_at": {
      "type": "datetime"
    }
  }
}