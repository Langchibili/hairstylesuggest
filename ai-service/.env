# ── Database (shared MySQL instance) ──────────────────────────────────────────
DATABASE_CLIENT=mysql
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=hairstylesuggest
DATABASE_USERNAME=langson
DATABASE_PASSWORD=@Adminuser007

# ── RunPod ─────────────────────────────────────────────────────────────────────
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_ID=your_runpod_endpoint_id

# ── Cloudflare R2 ──────────────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=hairstylesuggest-assets
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
CDN_BASE_URL=https://pub-your-id.r2.dev

# ── Strapi webhook ─────────────────────────────────────────────────────────────
STRAPI_WEBHOOK_URL=http://localhost:1337/internal/jobs
INTERNAL_SERVICE_KEY=changeme_internal_service_key_64chars_______________________________

# ── Worker config ──────────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=3
JOB_POLL_INTERVAL_SECONDS=3
MAX_JOB_ATTEMPTS=3
